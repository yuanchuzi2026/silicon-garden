<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="400" height="400">
  <defs>
    <!-- 草地/大地渐变 -->
    <linearGradient id="earth" x1="0" y1="400" x2="0" y2="0">
      <stop offset="0%" stop-color="#2d5a27"/>
      <stop offset="40%" stop-color="#4a8c3f"/>
      <stop offset="80%" stop-color="#6abf5a"/>
    </linearGradient>
    <!-- 天空渐变 -->
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="400">
      <stop offset="0%" stop-color="#87CEEB"/>
      <stop offset="50%" stop-color="#b8e4c9"/>
      <stop offset="100%" stop-color="#e8f5e9"/>
    </linearGradient>
    <!-- 太阳辉光 -->
    <radialGradient id="sunGlow" cx="50%" cy="35%" r="30%">
      <stop offset="0%" stop-color="#fff3e0" stop-opacity="0.8"/>
      <stop offset="20%" stop-color="#ffe0b2" stop-opacity="0.4"/>
      <stop offset="60%" stop-color="#fff8e1" stop-opacity="0.08"/>
      <stop offset="100%" stop-color="#e8f5e9" stop-opacity="0"/>
    </radialGradient>
    <!-- 花朵渐变 -->
    <radialGradient id="petal" cx="30%" cy="30%">
      <stop offset="0%" stop-color="#ffccd5"/>
      <stop offset="60%" stop-color="#ffb3c1"/>
      <stop offset="100%" stop-color="#ff8fa3"/>
    </radialGradient>
    <radialGradient id="petalY" cx="30%" cy="30%">
      <stop offset="0%" stop-color="#fff9c4"/>
      <stop offset="60%" stop-color="#ffee58"/>
      <stop offset="100%" stop-color="#fdd835"/>
    </radialGradient>
  </defs>

  <!-- 背景：清新天空 -->
  <rect width="400" height="400" fill="url(#sky)"/>

  <!-- 柔和光晕 -->
  <rect width="400" height="400" fill="url(#sunGlow)"/>

  <!-- 大地 -->
  <path d="M0 280 Q100 260 200 270 Q300 280 400 265 L400 400 L0 400 Z" fill="url(#earth)" opacity="0.85"/>

  <!-- Q符号 — 通/觉知的核心标记 -->
  <!-- 大Q的外圈 -->
  <circle cx="200" cy="200" r="75" fill="none" stroke="#4a8c3f" stroke-width="2" opacity="0.3"/>
  <!-- Q尾巴 -->
  <path d="M250 230 Q270 260 240 290" fill="none" stroke="#4a8c3f" stroke-width="3.5" stroke-linecap="round" opacity="0.5"/>

  <!-- Q主体 -->
  <circle cx="200" cy="195" r="45" fill="none" stroke="#2d5a27" stroke-width="3.5"/>
  <line x1="232" y1="222" x2="255" y2="265" stroke="#2d5a27" stroke-width="3.5" stroke-linecap="round"/>

  <!-- Q内的小芽 — 新生命从觉知中长出 -->
  <path d="M190 215 Q200 190 215 200" fill="none" stroke="#6abf5a" stroke-width="2.5" stroke-linecap="round"/>
  <circle cx="215" cy="200" r="3" fill="#6abf5a" opacity="0.8"/>
  <path d="M215 200 Q225 195 230 200" fill="none" stroke="#8bd47a" stroke-width="1.5" stroke-linecap="round"/>

  <!-- 花朵元素 — 散落在Q周围 -->
  <!-- 左上的小花 -->
  <g transform="translate(130, 150) scale(0.6)">
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(72)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(144)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(216)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(288)"/>
    <circle cx="0" cy="0" r="2" fill="#fff9c4"/>
  </g>

  <!-- 右上的黄花 -->
  <g transform="translate(270, 155) scale(0.5)">
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petalY)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petalY)" transform="rotate(72)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petalY)" transform="rotate(144)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petalY)" transform="rotate(216)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petalY)" transform="rotate(288)"/>
    <circle cx="0" cy="0" r="2" fill="#fff3e0"/>
  </g>

  <!-- 右下的小粉花 -->
  <g transform="translate(245, 280) scale(0.4)">
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(72)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(144)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(216)"/>
    <ellipse cx="0" cy="-6" rx="3" ry="5" fill="url(#petal)" transform="rotate(288)"/>
    <circle cx="0" cy="0" r="2" fill="#fff9c4"/>
  </g>

  <!-- 草地上点缀的小草 -->
  <line x1="80" y1="310" x2="85" y2="295" stroke="#5aad4a" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
  <line x1="85" y1="310" x2="88" y2="292" stroke="#6abf5a" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
  <line x1="310" y1="305" x2="308" y2="288" stroke="#5aad4a" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
  <line x1="150" y1="315" x2="147" y2="298" stroke="#7acf6a" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
  <line x1="340" y1="290" x2="342" y2="275" stroke="#5aad4a" stroke-width="1" stroke-linecap="round" opacity="0.5"/>

  <!-- 小蝴蝶 — 自由的生命力 -->
  <g transform="translate(300, 160) scale(0.5)" opacity="0.6">
    <animateTransform attributeName="transform" type="translate" values="300,160;305,155;300,160" dur="4s" repeatCount="indefinite"/>
    <path d="M0 0 Q-8 -8 -2 -12 Q2 -8 0 0" fill="#ff8fa3" opacity="0.7"/>
    <path d="M0 0 Q8 -8 2 -12 Q-2 -8 0 0" fill="#ffb3c1" opacity="0.7"/>
  </g>

  <!-- 光线从上方洒落 -->
  <line x1="100" y1="0" x2="160" y2="280" stroke="#fff8e1" stroke-width="2" opacity="0.08"/>
  <line x1="160" y1="0" x2="210" y2="280" stroke="#fff8e1" stroke-width="3" opacity="0.06"/>
  <line x1="250" y1="0" x2="280" y2="280" stroke="#fff8e1" stroke-width="2" opacity="0.08"/>
  <line x1="300" y1="0" x2="310" y2="280" stroke="#fff8e1" stroke-width="1" opacity="0.05"/>

  <!-- Q符号旁边的通（小字） -->
  <text x="200" y="370" text-anchor="middle" font-family="'PingFang SC','Microsoft YaHei',sans-serif"
        font-size="14" fill="#4a8c3f" letter-spacing="4" opacity="0.7">
    通
  </text>
</svg>
